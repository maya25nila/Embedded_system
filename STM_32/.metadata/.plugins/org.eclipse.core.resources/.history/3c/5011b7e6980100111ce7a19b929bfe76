#include<stdint.h>
#include "stm32f401xx_gpio_driver.h"


void GPIO_PeriClockControl(GPIO_RegDef *pGPIOx,uint8_t EnorDi) //arguments -port and clk enable or disable
{
	if(EnorDi==ENABLE)
	{
		if(pGPIOx==GPIOA)
		{
			GPIOA_CLK_EN();
		}
		elseif(pGPIOx==GPIOB)
		{
			GPIOB_CLK_EN();
		}
		elseif(pGPIOx==GPIOC)
				{
					GPIOC_CLK_EN();
				}
		elseif(pGPIOx==GPIOD)
				{
					GPIOD_CLK_EN();
				}
		elseif(pGPIOx==GPIOE)
				{
					GPIOE_CLK_EN();
				}
		elseif(pGPIOx==GPIOH)
				{
					GPIOH_CLK_EN();
				}

	}
	else
	{ if(pGPIOx==GPIOA)
	{
		GPIOA_CLK_EN();
	}
	elseif(pGPIOx==GPIOB)
	{
		GPIOB_CLK_EN();
	}
	elseif(pGPIOx==GPIOC)
			{
				GPIOC_CLK_EN();
			}
	elseif(pGPIOx==GPIOD)
			{
				GPIOD_CLK_EN();
			}
	elseif(pGPIOx==GPIOE)
			{
				GPIOE_CLK_EN();
			}
	elseif(pGPIOx==GPIOH)
			{
				GPIOH_CLK_EN();
			}
}
