#ifndef INC_STM32F401XX_I2C_DRIVER_H_
#define INC_STM32F401XX_I2C_DRIVER_H_

#include "stm32f401xx.h"

/*
 *  configuration structure for I2C Peripherals ***/
typedef struct{
	uint32_t I2C_SCLSpeed;
	uint8_t I2C_DeviceAddress;//for sub node address
	uint8_t I2C_AckControl;
	uint8_t I2C_FMDutyCycle;

}I2C_Config;
typedef struct{
	I2C_RegDef *pI2Cx;//structure pointer to  I2C base address
	I2C_Config  I2C_Config_t;//structure configuration variable
}I2C_Handle;

/*
 * I2C_SCLSpeed Macros
 */
#define I2C_SCL_SPEED_SM     100000    //STANDARD MODE
#define I2C_SCL_SPEED_FM     400000     //FAST MODE

/*
 * I2C_AckControl Macros
 */
#define I2C_ACK_ENABLE         1
#define I2C_ACK_DISABLE        0
/*
 * I2C_FMDutyCycle Macros
 */
#define I2C_FMDUTY_2            0
#define I2C_FMDUTY_16_9         1
/*
 * I2C API'S
 */
void I2C_PeriClockControl(I2C_RegDef *pI2Cx,uint8_t EnorDi);
void I2C_Init(I2C_Handle *pI2CHandle);
void I2C_DeInit(I2C_RegDef *pI2Cx);
void I2C_MainsendData();
void I2C_ReceiveData();
/*
 * I2C RELATED STATUS FLAG DEFINITION
 */
#define I2C_FLAG_TXE             (  1 << I2C_SR1_TXE)
#define I2C_FLAG_RXNE            (  1 << I2C_SR1_RXNE)
#define I2C_FLAG_SB              (  1 << I2C_SR1_SB)
#define I2C_FLAG_OVR             (  1 << I2C_SR1_OVR)
#define I2C_FLAG_AF	             (  1 << I2C_SR1_AF)
#define I2C_FLAG_ARLO            (  1 << I2C_SR1_ARLO)
#define I2C_FLAG_BERR            (  1 << I2C_SR1_BERR)
#define I2C_FLAG_STOPF           (  1 << I2C_SR1_STOPF)
#define I2C_FLAG_ADD10           (  1 << I2C_SR1_ADD10)
#define I2C_FLAG_BTF             (  1 << I2C_SR1_BTF)
#define I2C_FLAG_ADDR            (  1 << I2C_SR1_ADDR)
#define I2C_FLAG_TIMEOUT         (  1 << I2C_SR1_TIMEOUT)


#endif /* INC_STM32F401XX_I2C_DRIVER_H_ */
